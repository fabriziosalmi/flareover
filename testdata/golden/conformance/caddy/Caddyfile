{
	order waf first
	order cache before rewrite
	cache
}

(waf) {
	waf {
		rule_file /etc/caddy/waf/rules.json
		rate_limit {
			requests 20
			window 10s
			paths /login
		}
		block_asns 64512
		block_countries GeoLite2-Country.mmdb CN
		ip_blacklist_file /etc/caddy/waf/ip_blacklist.txt
		ip_whitelist_file /etc/caddy/waf/ip_whitelist.txt
	}
}

*.conformance.example {
	tls /etc/caddy/certs/*.conformance.example/fullchain.pem /etc/caddy/certs/*.conformance.example/privkey.pem
	tls {
		protocols tls1.2
	}
	header Strict-Transport-Security "max-age=31536000; includeSubDomains"
	header X-Content-Type-Options "nosniff"
	header X-Frame-Options "DENY"
	import waf
	cache
	reverse_proxy https://10.0.0.10:8080 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

