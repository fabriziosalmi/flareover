# Build artifacts
/flareover
/dist/
*.exe

# Per-migration working state (generated; keep out of the public repo)
/decisions.lock
/out/
# Real per-migration snapshots stay out — but the SANITIZED test fixtures are
# tracked, so a fresh clone can run `go test` (the suite reads them).
*.snapshot.json
!testdata/fixtures/*.snapshot.json

# Local env / secrets
.env
*.local

# Go
/vendor/

# Infrastructure notes, recon, deploy artifacts, secrets — NEVER tracked
/infra/

# Private roadmap scratch — never tracked
/PLAN.md

# macOS
.DS_Store

.claude/
# deploy/ generated artifacts + secrets
deploy/out/

# Terraform — plugins/state/secrets never tracked; the lock file IS (pinned
# provider versions), and *.tfvars.example is the sanitized template.
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
