# flareover deploy/: copy to .env and fill in. Never commit .env.

# Where `flareover prepare --out <dir>` wrote the artifacts (Caddyfile, WAF rules).
ARTIFACTS=./out

# PowerDNS API key (also passed to `provision --pdns-key`).
PDNS_API_KEY=change-me-a-long-random-key

# CertMate API bearer token: MUST be 32–512 chars (also `provision --certmate-token`).
CERTMATE_TOKEN=change-me-to-a-32-to-512-char-random-token-xxxxxxxx

# MinIO root credentials.
MINIO_ROOT_USER=flareover
MINIO_ROOT_PASSWORD=change-me-a-strong-password

# Optional image overrides (default to the published :latest).
# CERTMATE_IMAGE=ghcr.io/fabriziosalmi/certmate:latest
# SPM_IMAGE=ghcr.io/fabriziosalmi/secure-proxy-manager:latest
